NODE_ENV=development
APP_NAME=evidence-system
APP_VERSION=1.0.0
APP_LOCALE_DEFAULT=es
TZ=UTC

DATABASE_URL=postgres://postgres:postgres@localhost:5432/evidence
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=15000

LEDGER_STRICT=true
LEDGER_REQUIRE_PREV_HASH=true
LEDGER_HASH_ALGO=sha256
LEDGER_CANONICALIZATION=json-stable
LEDGER_VERIFY_ON_EXPORT=true

IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_TTL_HOURS=72

EXPORT_OUTPUT_DIR=exports
EXPORT_INCLUDE_BINARIES=false
EXPORT_FORMAT_VERSION=EVIDENCE_EXPORT_ZIP_V1
EXPORT_MANIFEST_VERSION=MANIFEST_V1
EXPORT_MAX_EVENTS=100000
EXPORT_NOTES_ES=Exportación probatoria. Integridad y trazabilidad verificables.
EXPORT_NOTES_EN=Forensic export. Integrity and traceability verifiable.

SIGN_PDF_ENABLED=false
SIGN_PROVIDER=local
SIGN_CERT_PATH=/secure/certs/cert.p12
SIGN_CERT_PASSWORD=change_me
SIGN_PDF_PROFILE=PAdES-LTA
SIGN_TSA_URL=https://tsa.example.org

NLP_ENABLED=false
NLP_PROVIDER=spacy
NLP_SERVICE_URL=http://localhost:8000
NLP_TIMEOUT_MS=5000
NLP_LANGUAGE_DEFAULT=es

LOG_LEVEL=info
LOG_FORMAT=json
MAX_REQUEST_SIZE_KB=1024
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQ_PER_MIN=60

ALLOW_DIRECT_DB_ACCESS=false
ALLOW_TEST_SCRIPTS=false
